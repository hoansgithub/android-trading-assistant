<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AlphaProfitAI" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <!-- Splash screen theme (Android 12+ SplashScreen API) -->
    <style name="Theme.AlphaProfitAI.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="postSplashScreenTheme">@style/Theme.AlphaProfitAI</item>
    </style>

</resources>
